# htdocs-explorer — enrutado del explorador moderno.
#
# Idea: cualquier carpeta que NO tenga su propio index.(php|html) se sirve con el
# explorador (src/app.php). Las carpetas que sí tienen index se dejan intactas,
# así puedes navegar dentro de tus proyectos con normalidad. Esto conserva la
# magia de "soltar en htdocs y navegar cualquier carpeta", sin depender del
# frágil mod_autoindex/HeaderName de la versión anterior.

Options -Indexes +FollowSymLinks
DirectoryIndex index.php index.html index.htm

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Normaliza URLs de carpeta añadiendo la barra final (evita rutas relativas rotas).
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_URI} !/$
    RewriteRule ^ %{REQUEST_URI}/ [R=302,L]

    # Sirve el explorador solo para carpetas reales SIN index propio.
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_FILENAME}/index.php !-f
    RewriteCond %{REQUEST_FILENAME}/index.html !-f
    RewriteCond %{REQUEST_FILENAME}/index.htm !-f
    RewriteRule ^ /src/app.php [L]
</IfModule>

# Subir archivos más grandes (solo aplica con PHP como módulo de Apache).
<IfModule mod_php.c>
    php_value upload_max_filesize 128M
    php_value post_max_size 130M
</IfModule>

# Página de error propia.
ErrorDocument 404 /src/404.php
